[node name="PlayerSpawn" parent="." unique_id=1923900023 instance=ExtResource("5_dfkt3")]
z_index = 2
position = Vector2(41, 42)

[node name="LevelTransition" parent="." unique_id=1043469762 instance=ExtResource("6_1rsp4")]
position = Vector2(120, 17)
level = "uid://bodokar5axh1u"
size = 1
side = 3

[node name="MirrorText" type="Node2D" parent="." unique_id=1001004886]
position = Vector2(-33, -36)

[node name="DialogInteraction" parent="MirrorText" unique_id=70852569 instance=ExtResource("7_fkxkw")]
position = Vector2(73, 8)

[node name="DialogText" type="Node" parent="MirrorText/DialogInteraction" unique_id=1675155955]
script = ExtResource("8_fhi6l")
text = "The lack of quality sleep has begun to show on your face. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="MirrorText/DialogInteraction" unique_id=161082110]
script = ExtResource("8_fhi6l")
text = "You’ve grown pale and weary, and you don’t remember the last time you’ve eaten. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="MirrorText/DialogInteraction" unique_id=1989378900]
script = ExtResource("8_fhi6l")
text = "There’s no time left to worry about it anymore. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="CouchText" type="Node2D" parent="." unique_id=1664682370]
position = Vector2(-60, -24)

[node name="DialogInteraction" parent="CouchText" unique_id=1059321773 instance=ExtResource("7_fkxkw")]
position = Vector2(73, 8)

[node name="DialogText" type="Node" parent="CouchText/DialogInteraction" unique_id=1591777425]
script = ExtResource("8_fhi6l")
text = "You’ve ran out of room to stack your dirty dishes, so some of them have started to pile on the floor to the side of the couch. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="CouchText/DialogInteraction" unique_id=1541916421]
script = ExtResource("8_fhi6l")
text = "It’ll have to do. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="CouchText/DialogInteraction" unique_id=156404672]
script = ExtResource("8_fhi6l")
text = "Who will see it anyway? "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DeskText" type="Node2D" parent="." unique_id=454444587]
position = Vector2(-2, 47)

[node name="DialogInteraction" parent="DeskText" unique_id=583075001 instance=ExtResource("7_fkxkw")]
position = Vector2(12, 41)

[node name="DialogText" type="Node" parent="DeskText/DialogInteraction" unique_id=100645279]
script = ExtResource("8_fhi6l")
text = "You’re confident that someone has been worried about you. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DeskText/DialogInteraction" unique_id=1174296310]
script = ExtResource("8_fhi6l")
text = "Yet no one texted you yesterday. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="BedText" type="Node2D" parent="." unique_id=629629102]
position = Vector2(2, -1)

[node name="DialogInteraction" parent="BedText" unique_id=806684207 instance=ExtResource("7_fkxkw")]
position = Vector2(12, 41)

[node name="DialogText" type="Node" parent="BedText/DialogInteraction" unique_id=230496615]
script = ExtResource("8_fhi6l")
text = "Your blankets have stayed in the same place since yesterday morning. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="BedText/DialogInteraction" unique_id=426176335]
script = ExtResource("8_fhi6l")
text = "Sleep has only manifested on the couch. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="Picture1Text" type="Node2D" parent="." unique_id=1063030674]
position = Vector2(61, -8)

[node name="DialogInteraction" parent="Picture1Text" unique_id=979044438 instance=ExtResource("7_fkxkw")]
position = Vector2(12, 41)

[node name="DialogText" type="Node" parent="Picture1Text/DialogInteraction" unique_id=318818086]
script = ExtResource("8_fhi6l")
text = "You avert your eyes from the painting. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="Picture1Text/DialogInteraction" unique_id=823079636]
script = ExtResource("8_fhi6l")
text = "The sight of it only brings you sadness. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="Picture1Text/DialogInteraction" unique_id=940959591]
script = ExtResource("8_fhi6l")
text = "You still can’t find your paintbrushes. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="Picture2Text" type="Node2D" parent="." unique_id=853266349]
position = Vector2(111, -72)

[node name="DialogInteraction" parent="Picture2Text" unique_id=858157174 instance=ExtResource("7_fkxkw")]
position = Vector2(12, 41)

[node name="DialogText" type="Node" parent="Picture2Text/DialogInteraction" unique_id=158218678]
script = ExtResource("8_fhi6l")
text = "You feel afraid that your friend can sense that you’ve left the painting lopsided. "
npc_info = ExtResource("9_if3xk")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="Picture2Text/DialogInteraction" unique_id=736745845]
script = ExtResource("8_fhi6l")
text = "You quickly turn it, but it only rotates back to the same side. "
npc_info = ExtResource("9_if3xk")
