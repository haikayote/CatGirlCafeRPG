[node name="CouchText" type="Node2D" parent="." unique_id=1664682370]
position = Vector2(-60, -24)

[node name="DialogInteraction" parent="CouchText" unique_id=1059321773 instance=ExtResource("7_qpcby")]
position = Vector2(73, 8)

[node name="DialogText" type="Node" parent="CouchText/DialogInteraction" unique_id=1591777425]
script = ExtResource("8_lekt1")
text = "Your couch has been there for you in your roughest moments."
npc_info = ExtResource("9_6hhom")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="CouchText/DialogInteraction" unique_id=1541916421]
script = ExtResource("8_lekt1")
text = "It's most comfortable when you're horribly hungover."
npc_info = ExtResource("9_6hhom")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DeskText" type="Node2D" parent="." unique_id=454444587]
position = Vector2(-2, 47)

[node name="DialogInteraction" parent="DeskText" unique_id=583075001 instance=ExtResource("7_qpcby")]
