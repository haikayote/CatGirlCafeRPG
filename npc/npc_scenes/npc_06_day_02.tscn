[node name="DialogText" type="Node" parent="DialogInteraction" unique_id=1509519335]
script = ExtResource("4_jieuc")
text = "Hi there, what can I get you today?"
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction" unique_id=1961526181]
script = ExtResource("4_jieuc")
text = "They're staring at their phone."
npc_info = ExtResource("6_qsf0k")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction" unique_id=153859731]
script = ExtResource("4_jieuc")
text = "Hi, what can I get for you today?"
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction" unique_id=553487884]
script = ExtResource("4_jieuc")
text = "..."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction" unique_id=1846174657]
script = ExtResource("4_jieuc")
text = "Can I get an iced oat milk latte?"
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction" unique_id=1063991625]
script = ExtResource("4_jieuc")
text = "Of course."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText7" type="Node" parent="DialogInteraction" unique_id=645852541]
script = ExtResource("4_jieuc")
text = "You make the drink carefully, making sure to sanitize your utensils prior to making the drink in case of cross-contamination."
npc_info = ExtResource("6_qsf0k")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText8" type="Node" parent="DialogInteraction" unique_id=401735172]
script = ExtResource("4_jieuc")
text = "Here you go."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText9" type="Node" parent="DialogInteraction" unique_id=1837154985]
script = ExtResource("4_jieuc")
text = "Um... where's my cold foam?"
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogChoice" type="Node" parent="DialogInteraction" unique_id=378143775]
script = ExtResource("7_r37rs")
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://bu72pcrg4ws6q"

[node name="DialogBranch" type="Node" parent="DialogInteraction/DialogChoice" unique_id=585955370]
script = ExtResource("8_yibpo")
text = "Pour it over."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch" unique_id=2005535103]
script = ExtResource("4_jieuc")
text = "Is this dairy-free?"
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch" unique_id=1817559492]
script = ExtResource("4_jieuc")
text = "No, I'm sorry, we can only make our cold foam with non-fat milk."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch" unique_id=2037390495]
script = ExtResource("4_jieuc")
text = "That's ridiculous."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch" unique_id=534472395]
script = ExtResource("4_jieuc")
text = "Take it off of my drink."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogChoice" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch" unique_id=1296014041]
script = ExtResource("7_r37rs")
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://bu72pcrg4ws6q"

[node name="DialogBranch" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice" unique_id=1067322775]
script = ExtResource("8_yibpo")
text = "Take it off."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=1888802313]
script = ExtResource("4_jieuc")
text = "You feel bad. "
npc_info = ExtResource("6_qsf0k")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=1052569811]
script = ExtResource("4_jieuc")
text = "There are still remnants of the cold foam in the drink."
npc_info = ExtResource("6_qsf0k")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=1611830499]
script = ExtResource("4_jieuc")
text = "It's contaminated."
npc_info = ExtResource("6_qsf0k")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=1781373802]
script = ExtResource("4_jieuc")
text = "I'm sorry."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=1486363061]
script = ExtResource("4_jieuc")
text = "Sure."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=1861580823]
script = ExtResource("4_jieuc")
text = "They take the drink anyway."
npc_info = ExtResource("6_qsf0k")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice" unique_id=115254707]
script = ExtResource("8_yibpo")
text = "Remake the drink."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch2" unique_id=2053894648]
script = ExtResource("4_jieuc")
text = "Wow, you're not even listening to what I was saying."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch2" unique_id=1149796149]
script = ExtResource("4_jieuc")
text = "I told you to just take it off."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch2" unique_id=1175321745]
script = ExtResource("4_jieuc")
text = "It's contaminated."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch2" unique_id=431364681]
script = ExtResource("4_jieuc")
text = "Whatever."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch2" unique_id=140544650]
script = ExtResource("4_jieuc")
text = "You're just wasting coffee."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch2" unique_id=1280350510]
script = ExtResource("4_jieuc")
text = "They take the new drink, without cold foam."
npc_info = ExtResource("6_qsf0k")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch2" type="Node" parent="DialogInteraction/DialogChoice" unique_id=996844171]
script = ExtResource("8_yibpo")
text = "Educate the customer."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2" unique_id=1173982017]
script = ExtResource("4_jieuc")
text = "Our cold foam is made with non-fat milk, which has lactose in it."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2" unique_id=810184639]
script = ExtResource("4_jieuc")
text = "Oh, okay."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2" unique_id=1949424817]
script = ExtResource("4_jieuc")
text = "I still want it, but I'm allergic to dairy. Is there anything you can do?"
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogChoice" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2" unique_id=565864578]
script = ExtResource("7_r37rs")
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://bu72pcrg4ws6q"

[node name="DialogBranch" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice" unique_id=1881211117]
script = ExtResource("8_yibpo")
text = "Try to make it non-dairy."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch" unique_id=48911749]
script = ExtResource("4_jieuc")
text = "It doesn't come out the way it typically does. It's too liquidy."
npc_info = ExtResource("6_qsf0k")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch" unique_id=1386318048]
script = ExtResource("4_jieuc")
text = "This isn't cold foam."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch" unique_id=1321914418]
script = ExtResource("4_jieuc")
text = "This is just milk on top of my coffee."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch" unique_id=869313474]
script = ExtResource("4_jieuc")
text = "I'm sorry, there's nothing we can put into it to make it thicker."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch" unique_id=788323198]
script = ExtResource("4_jieuc")
text = "Whatever."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch" unique_id=842030095]
script = ExtResource("4_jieuc")
text = "It's fine, I guess."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText7" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch" unique_id=2036330134]
script = ExtResource("4_jieuc")
text = "They leave unhappy."
npc_info = ExtResource("6_qsf0k")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice" unique_id=356910957]
script = ExtResource("8_yibpo")
text = "Stand strong."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch2" unique_id=1172589740]
script = ExtResource("4_jieuc")
text = "There's simply nothing I can do at this shop."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch2" unique_id=2068518489]
script = ExtResource("4_jieuc")
text = "We're not supposed to make cold foam with anything other than nonfat milk."
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch2" unique_id=52562610]
script = ExtResource("4_jieuc")
text = "That's ridiculous."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch2" unique_id=1146469127]
script = ExtResource("4_jieuc")
text = "I've gotten it before from another person."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch2" unique_id=1912263873]
script = ExtResource("4_jieuc")
text = "Maybe they just used dairy in their cold foam?"
npc_info = ExtResource("5_wad0f")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch2" unique_id=1494384882]
script = ExtResource("4_jieuc")
text = "That's insane!"
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText7" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch2" unique_id=507380515]
script = ExtResource("4_jieuc")
text = "I can't believe this."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText8" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch2" unique_id=2072631956]
script = ExtResource("4_jieuc")
text = "I'm leaving."
npc_info = ExtResource("7_bvfue")
metadata/_custom_type_script = "uid://785rj1abomch"

