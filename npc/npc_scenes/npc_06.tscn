[node name="DialogInteraction" parent="." unique_id=974914508 instance=ExtResource("3_eijls")]

[node name="DialogText" type="Node" parent="DialogInteraction" unique_id=1509519335]
script = ExtResource("4_if5py")
text = "Hi there, what can I get you today?"
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction" unique_id=1961526181]
script = ExtResource("4_if5py")
text = "May I have something that..."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogChoice" type="Node" parent="DialogInteraction" unique_id=702963314]
script = ExtResource("7_wl0sx")
metadata/_custom_type_script = "uid://bu72pcrg4ws6q"

[node name="DialogBranch" type="Node" parent="DialogInteraction/DialogChoice" unique_id=680463303]
script = ExtResource("8_808ts")
text = "makes me feel alive"
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch" unique_id=54538822]
script = ExtResource("4_if5py")
text = "The daily responsibilities of adult life drag me down sometimes."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch" unique_id=632775075]
script = ExtResource("4_if5py")
text = "I just want to feel like I'm worthy of something more than whatever this life can offer."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch" unique_id=616503009]
script = ExtResource("4_if5py")
text = "Please help me do that."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogChoice" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch" unique_id=658766813]
script = ExtResource("7_wl0sx")
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://bu72pcrg4ws6q"

[node name="DialogBranch" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice" unique_id=1256496885]
script = ExtResource("8_808ts")
text = "I don't know how to do that."
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=718776785]
script = ExtResource("4_if5py")
text = "I'm sorry, I think we just serve coffee here."
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=1883585896]
script = ExtResource("4_if5py")
text = "That's okay."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=1020530260]
script = ExtResource("4_if5py")
text = "I just thought maybe someone would be able to break this monotony."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=1245568582]
script = ExtResource("4_if5py")
text = "I hope you don't think I'm using you."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=1976490212]
script = ExtResource("4_if5py")
text = "I'll just have a coffee."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch" unique_id=2090131552]
script = ExtResource("4_if5py")
text = "Caffeine is easier to abuse than using people."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice" unique_id=390673739]
script = ExtResource("8_808ts")
text = "I can try."
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch2" unique_id=1684953222]
script = ExtResource("4_if5py")
text = "Maybe coffee will help you feel more alive."
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch2" unique_id=1031740607]
script = ExtResource("4_if5py")
text = "It'll help me feel awake, not alive."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch2" unique_id=1339694814]
script = ExtResource("4_if5py")
text = "I'm awake right now, but this isn't a life to live."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch/DialogChoice/DialogBranch2" unique_id=834174251]
script = ExtResource("4_if5py")
text = "Whatever, it's good enough. Maybe it'll help me reach an epiphany."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch2" type="Node" parent="DialogInteraction/DialogChoice" unique_id=1381994461]
script = ExtResource("8_808ts")
text = "lets me forget"
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2" unique_id=1769926419]
script = ExtResource("4_if5py")
text = "I want to forget the upcoming trials of the new day."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2" unique_id=50517136]
script = ExtResource("4_if5py")
text = "Could you help me do that? What do you suggest?"
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogChoice" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2" unique_id=1804991750]
script = ExtResource("7_wl0sx")
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://bu72pcrg4ws6q"

[node name="DialogBranch" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice" unique_id=1093960697]
script = ExtResource("8_808ts")
text = "A calm cup of chamomile tea."
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch" unique_id=971664559]
script = ExtResource("4_if5py")
text = "That would certainly help me relax, but I don't think it would let me forget."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch" unique_id=376192652]
script = ExtResource("4_if5py")
text = "Who can help me if you can't?"
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch" unique_id=719059723]
script = ExtResource("4_if5py")
text = "I'm relying on you to make me feel better."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch" unique_id=1651027925]
script = ExtResource("4_if5py")
text = "I'll take it anyway, but I'll be back if it doesn't help."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice" unique_id=1706255709]
script = ExtResource("8_808ts")
text = "A strong, bitter double shot of espresso."
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch2" unique_id=437696184]
script = ExtResource("4_if5py")
text = "That'll certainly keep me awake, but it won't let me forget."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch2" unique_id=619244993]
script = ExtResource("4_if5py")
text = "In fact, it'll only amplify the persistence of the problems of today."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2/DialogChoice/DialogBranch2" unique_id=373818905]
script = ExtResource("4_if5py")
text = "I'll take it anyway, but I'll be back if it doesn't help."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch3" type="Node" parent="DialogInteraction/DialogChoice" unique_id=157053538]
script = ExtResource("8_808ts")
text = "keeps me calm"
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3" unique_id=1085824059]
script = ExtResource("4_if5py")
text = "I need something that'll help my anxiety for the upcoming day."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3" unique_id=210154093]
script = ExtResource("4_if5py")
text = "What do you recommend?"
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogChoice" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3" unique_id=1499680026]
script = ExtResource("7_wl0sx")
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://bu72pcrg4ws6q"

[node name="DialogBranch" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice" unique_id=2014071294]
script = ExtResource("8_808ts")
text = "A hot cup of peppermint tea."
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch" unique_id=216252701]
script = ExtResource("4_if5py")
text = "That'll certainly calm down the nerves."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch" unique_id=856655680]
script = ExtResource("4_if5py")
text = "Thank you for the suggestion, I'm sorry to be so difficult."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch" unique_id=742737554]
script = ExtResource("4_if5py")
text = "I just can't make decisions when I'm so nervous about other matters."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch" unique_id=279275760]
script = ExtResource("4_if5py")
text = "I'll enjoy it here before I go."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice" unique_id=1354934639]
script = ExtResource("8_808ts")
text = "A glass of chocolate milk."
npc_info = ExtResource("5_5odc4")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch2" unique_id=484801004]
script = ExtResource("4_if5py")
text = "That would certainly allow me to relax for a short moment before the day starts."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch2" unique_id=708996586]
script = ExtResource("4_if5py")
text = "Thank you for the suggestion, I'm sorry to be so difficult."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch2" unique_id=1486663258]
script = ExtResource("4_if5py")
text = "I just can't make decisions when I'm so nervous about the day ahead of me."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch2" unique_id=180815206]
script = ExtResource("4_if5py")
text = "I'll enjoy it in the shop before I get ready for my day."
npc_info = ExtResource("6_8oxjn")
metadata/_custom_type_script = "uid://785rj1abomch"

