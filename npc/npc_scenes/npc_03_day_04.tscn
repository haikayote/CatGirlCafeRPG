[node name="DialogInteraction" parent="." instance=ExtResource("5_826bx")]

[node name="DialogText" type="Node" parent="DialogInteraction"]
script = ExtResource("6_dibs3")
text = "You’re pushing your limits by taking this next customer."
npc_info = ExtResource("9_hawtu")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction"]
script = ExtResource("6_dibs3")
text = "It may be time to throw in the towel."
npc_info = ExtResource("9_hawtu")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction"]
script = ExtResource("6_dibs3")
text = "I can’t do this anymore."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction"]
script = ExtResource("6_dibs3")
text = "Sorry?"
npc_info = ExtResource("7_q1h08")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction"]
script = ExtResource("6_dibs3")
text = "I can’t do this anymore."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction"]
script = ExtResource("6_dibs3")
text = "Are you... okay?"
npc_info = ExtResource("7_q1h08")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText7" type="Node" parent="DialogInteraction"]
script = ExtResource("6_dibs3")
text = "I can’t do this anymore."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText8" type="Node" parent="DialogInteraction"]
script = ExtResource("6_dibs3")
text = "Who are you?"
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText9" type="Node" parent="DialogInteraction"]
script = ExtResource("6_dibs3")
text = "I just wanted to order a coffee..."
npc_info = ExtResource("7_q1h08")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogChoice" type="Node" parent="DialogInteraction"]
script = ExtResource("10_67ulv")
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://bu72pcrg4ws6q"

[node name="DialogBranch" type="Node" parent="DialogInteraction/DialogChoice"]
script = ExtResource("11_3eq7j")
text = "Avoid the conversation."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_dibs3")
text = "..."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_dibs3")
text = "What?"
npc_info = ExtResource("7_q1h08")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_dibs3")
text = "Their voice starts to ring in your ears."
npc_info = ExtResource("9_hawtu")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_dibs3")
text = "You need it to end."
npc_info = ExtResource("9_hawtu")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_dibs3")
text = "Hello? "
npc_info = ExtResource("7_q1h08")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_dibs3")
text = "You walk away, unable to cope with your environment."
npc_info = ExtResource("9_hawtu")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch2" type="Node" parent="DialogInteraction/DialogChoice"]
script = ExtResource("11_3eq7j")
text = "Express your frustrations."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "I can’t understand people like you."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "You come to me, demanding service."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "Why do you get to do that?"
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "Why do I have to serve you?"
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "You’re leeching the life out of the workers that support this society. "
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "Woah, I didn’t- "
npc_info = ExtResource("7_q1h08")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText7" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "People like you make me sick."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText8" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "Get out of my face."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch3" type="Node" parent="DialogInteraction/DialogChoice"]
script = ExtResource("11_3eq7j")
text = "Refuse their service."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("6_dibs3")
text = "I can’t take your order."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("6_dibs3")
text = "I’m sorry."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("6_dibs3")
text = "What do you mean?"
npc_info = ExtResource("7_q1h08")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("6_dibs3")
text = "Are you closing? "
npc_info = ExtResource("7_q1h08")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogChoice" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("10_67ulv")
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://bu72pcrg4ws6q"

[node name="DialogBranch" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice"]
script = ExtResource("11_3eq7j")
text = "Lie. "
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch"]
script = ExtResource("6_dibs3")
text = "Yes, we’re closing early. "
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch"]
script = ExtResource("6_dibs3")
text = "I’m sorry."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch"]
script = ExtResource("6_dibs3")
text = "You start to choke back tears."
npc_info = ExtResource("9_hawtu")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch"]
script = ExtResource("6_dibs3")
text = "You want this experience to end. "
npc_info = ExtResource("9_hawtu")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice"]
script = ExtResource("11_3eq7j")
text = "Tell the truth."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "I can’t handle this anymore."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "I’m not built for a job like this."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "Day and night, working like a dog while keeping a smile the whole time."
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "Do you get pleasure out of seeing us like this? "
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "Is this worth it for you?"
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "I don’t know you. "
npc_info = ExtResource("7_q1h08")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText7" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3/DialogChoice/DialogBranch2"]
script = ExtResource("6_dibs3")
text = "Of course you don’t. And you never cared to. "
npc_info = ExtResource("8_3l1u2")
metadata/_custom_type_script = "uid://785rj1abomch"
