[node name="DialogInteraction" parent="." instance=ExtResource("5_a6l3o")]

[node name="DialogText" type="Node" parent="DialogInteraction"]
script = ExtResource("6_43lh4")
text = "[wave]Hello![/wave] How may I help you? "
npc_info = ExtResource("7_1uret")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction"]
script = ExtResource("6_43lh4")
text = "Can I get uh... [shake]uhm... "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogChoice" type="Node" parent="DialogInteraction"]
script = ExtResource("9_m0xte")
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://bu72pcrg4ws6q"

[node name="DialogBranch" type="Node" parent="DialogInteraction/DialogChoice"]
script = ExtResource("10_ef4my")
text = "something sweet?"
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_43lh4")
text = "My life feels like it’s only stress. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_43lh4")
text = "Every day is the same. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_43lh4")
text = "I just want something different.  "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_43lh4")
text = "Something that feels like bliss. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_43lh4")
text = "I understand. "
npc_info = ExtResource("7_1uret")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_43lh4")
text = "They hold the cup protectively. "
npc_info = ExtResource("11_ydvav")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText7" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_43lh4")
text = "As if it were something fragile. "
npc_info = ExtResource("11_ydvav")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText8" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_43lh4")
text = "As if it could disappear. "
npc_info = ExtResource("11_ydvav")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText9" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch"]
script = ExtResource("6_43lh4")
text = "Thank you for this moment.  "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch2" type="Node" parent="DialogInteraction/DialogChoice"]
script = ExtResource("10_ef4my")
text = "something bitter?"
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "Sweet things make me feel worse. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "Like I’m pretending everything is fine. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "Bitter is honest. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "Sure. "
npc_info = ExtResource("7_1uret")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "They watch the liquid fill the cup. "
npc_info = ExtResource("11_ydvav")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText6" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "Dark. "
npc_info = ExtResource("11_ydvav")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText7" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "Still. "
npc_info = ExtResource("11_ydvav")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText8" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "My mother used to drink coffee like this. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText9" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "No sugar. No cream. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText10" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "She said it was something adults did. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText11" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "She said I’d understand when I got older. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText12" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch2"]
script = ExtResource("6_43lh4")
text = "I wish I didn’t. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogBranch3" type="Node" parent="DialogInteraction/DialogChoice"]
script = ExtResource("10_ef4my")
text = "something cheap?"
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://dhh7suegfpi4q"

[node name="DialogText" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("6_43lh4")
text = "I can’t bear spending so much on myself. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText2" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("6_43lh4")
text = "I don’t understand why people do it, why anyone does it. "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText3" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("6_43lh4")
text = "Do you? "
npc_info = ExtResource("8_e5h26")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText4" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("6_43lh4")
text = "..I don’t know. "
npc_info = ExtResource("7_1uret")
metadata/_custom_type_script = "uid://785rj1abomch"

[node name="DialogText5" type="Node" parent="DialogInteraction/DialogChoice/DialogBranch3"]
script = ExtResource("6_43lh4")
text = "A worthless cup is poured. "
npc_info = ExtResource("11_ydvav")
metadata/_custom_type_script = "uid://785rj1abomch"
